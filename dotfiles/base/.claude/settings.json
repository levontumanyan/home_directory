{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",
      "Bash(git tag *)",
      "Bash(git blame *)",
      "Bash(git shortlog *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh pr review *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",
      "Bash(gh search *)",
      "Bash(bk build view *)",
      "Bash(bk artifacts *)",
      "Bash(bk pipeline view *)",
      "Bash(bk build list *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl top *)",
      "Bash(kubectl explain *)",
      "Bash(grep -r *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(curl -s *)",
      "Bash(curl --silent *)",
      "WebSearch"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/buildkite-guard.py",
            "statusMessage": "Checking buildkite guard..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "theme": "dark",
  "skipAutoPermissionPrompt": true
}
