#!/bin/bash

# Only trigger alerts for operations that likely require a YubiKey touch
# (signing or decrypting)
SHOULD_ALERT=0
for arg in "$@"; do
	# Check for:
	# 1. Bundled short flags containing 's' (sign), 'b' (detach-sign), or 'd' (decrypt)
	#    Ensuring it starts with '-' and isn't just a long flag or path
	# 2. Explicit long flags
	if [[ $arg =~ ^-[a-zA-Z]*[sbd][a-zA-Z]*$ ]] ||
		[[ $arg == "--sign" ]] ||
		[[ $arg == "--clearsign" ]] ||
		[[ $arg == "--detach-sign" ]] ||
		[[ $arg == "--decrypt" ]] ||
		[[ $arg == "--edit-key" ]]; then
		SHOULD_ALERT=1
		break
	fi
done

if [ "$SHOULD_ALERT" -eq 1 ]; then
	afplay /System/Library/Sounds/Glass.aiff &
	osascript -e 'display notification "Waiting for YubiKey touch..." with title "GPG Auth"' &
fi

exec /opt/homebrew/bin/gpg "$@"
