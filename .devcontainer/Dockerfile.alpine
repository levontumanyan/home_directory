FROM alpine:latest

# Install minimal testing dependencies
RUN apk add --no-cache \
    zsh \
    git \
    curl \
    stow \
    sudo \
    bash \
    build-base

# Create user 'ubuntu' (matching your other container)
RUN adduser -D -s /bin/zsh ubuntu && \
    echo "ubuntu ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER ubuntu
WORKDIR /workspace
